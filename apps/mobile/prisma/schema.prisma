generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://neondb_owner:npg_ZyFaNDnKY72q@ep-old-violet-ai58a9t7-pooler.c-4.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
}

// ------------------------------------------------------
// USERS & CLIENTS
// ------------------------------------------------------

model UserProfile {
  id        String   @id @default(cuid())
  email     String   @unique
  firstName String?
  lastName  String?
  role      String   @default("ADMIN") // ADMIN, BROKER, AGENT
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  activities ActivityFeed[]
  notes      Note[]
  tasks      Task[]
}

model Client {
  id              String   @id @default(cuid())
  firstName       String
  lastName        String
  email           String   @unique
  phone           String?
  type            String   @default("INDIVIDUAL") // INDIVIDUAL, CORPORATE
  kycStatus       String   @default("PENDING") // PENDING, APPROVED, REJECTED
  creditScore     Int?
  monthlyIncome   Float?
  totalLiabilities Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  contacts     ClientContact[]
  properties   Property[]
  deals        DealParty[]
  documents    Document[]
}

model ClientContact {
  id         String   @id @default(cuid())
  clientId   String
  type       String   // PHONE, EMAIL, ADDRESS
  value      String
  isPrimary  Boolean  @default(false)
  
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

// ------------------------------------------------------
// PROPERTIES
// ------------------------------------------------------

model Property {
  id            String   @id @default(cuid())
  clientId      String
  address       String
  city          String?
  province      String?
  postalCode    String?
  propertyType  String   // DETACHED, TOWNHOUSE, CONDO, COMMERCIAL
  value         Float?
  occupancy     String?  // OWNER_OCCUPIED, RENTAL, SECOND_HOME
  annualTaxes   Float?
  condoFees     Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  client        Client   @relation(fields: [clientId], references: [id])
  deals         Deal[]
}

// ------------------------------------------------------
// DEALS & PIPELINE
// ------------------------------------------------------

model Deal {
  id            String   @id @default(cuid())
  title         String
  propertyId    String?
  stage         String   @default("NEW") // NEW, DOCS, IN_REVIEW, SUBMITTED, COMMITTED, FUNDED, CLOSED, LOST
  status        String   @default("ACTIVE") // ACTIVE, WON, LOST, ON_HOLD
  loanAmount    Float?
  purpose       String?  // PURCHASE, REFINANCE, RENEWAL, EQUITY
  closingDate   DateTime?
  targetLtv     Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  property      Property? @relation(fields: [propertyId], references: [id])
  parties       DealParty[]
  stageHistory  DealStageHistory[]
  notes         Note[]
  tasks         Task[]
  documents     Document[]
  docRequests   DocumentRequest[]
  matches       DealLenderMatch[]
  scenarios     Scenario[]
  calcRuns      CalculatorRun[]
}

model DealParty {
  id        String   @id @default(cuid())
  dealId    String
  clientId  String
  role      String   @default("PRIMARY_BORROWER") // PRIMARY_BORROWER, CO_BORROWER, GUARANTOR
  
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([dealId, clientId])
}

model DealStageHistory {
  id        String   @id @default(cuid())
  dealId    String
  oldStage  String?
  newStage  String
  changedAt DateTime @default(now())
  changedBy String?

  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
}

// ------------------------------------------------------
// TASKS & NOTES
// ------------------------------------------------------

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime?
  isCompleted Boolean  @default(false)
  dealId      String?
  assigneeId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  deal        Deal?        @relation(fields: [dealId], references: [id], onDelete: Cascade)
  assignee    UserProfile? @relation(fields: [assigneeId], references: [id])
}

model Note {
  id        String   @id @default(cuid())
  content   String
  dealId    String?
  authorId  String?
  createdAt DateTime @default(now())

  deal      Deal?        @relation(fields: [dealId], references: [id], onDelete: Cascade)
  author    UserProfile? @relation(fields: [authorId], references: [id])
}

// ------------------------------------------------------
// LENDERS & CRITERIA
// ------------------------------------------------------

model Lender {
  id          String   @id @default(cuid())
  name        String
  type        String   // A_LENDER, B_LENDER, MIC, PRIVATE
  isActive    Boolean  @default(true)
  logoUrl     String?
  contactInfo String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  capacities  LenderCapacity[]
  products    LenderProduct[]
  criteria    LenderCriteriaRule[]
  rateSheets  RateSheet[]
  matches     DealLenderMatch[]
}

model LenderCapacity {
  id             String   @id @default(cuid())
  lenderId       String
  totalCapital   Float
  deployedCapital Float   @default(0)
  vintageMonth   DateTime
  
  lender         Lender   @relation(fields: [lenderId], references: [id], onDelete: Cascade)
}

model LenderProduct {
  id          String   @id @default(cuid())
  lenderId    String
  name        String
  position    Int      @default(1) // 1 = 1st Mortgage, 2 = 2nd
  termMonths  Int?
  amortMonths Int?
  
  lender      Lender   @relation(fields: [lenderId], references: [id], onDelete: Cascade)
}

model LenderCriteriaRule {
  id          String   @id @default(cuid())
  lenderId    String
  version     Int      @default(1)
  rulesJson   String   // JSON representing maxLtv, minCredit, regions, propertyTypes, maxGds, maxTds
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  
  lender      Lender   @relation(fields: [lenderId], references: [id], onDelete: Cascade)
}

model RateSheet {
  id          String   @id @default(cuid())
  lenderId    String
  term        String   // e.g. "1YR", "5YR"
  rateType    String   // FIXED, VARIABLE
  rate        Float
  effectiveDate DateTime @default(now())
  
  lender      Lender   @relation(fields: [lenderId], references: [id], onDelete: Cascade)
}

model DealLenderMatch {
  id          String   @id @default(cuid())
  dealId      String
  lenderId    String
  score       Float
  status      String   @default("MATCHED") // MATCHED, SUBMITTED, DECLINED, APPROVED
  notes       String?
  createdAt   DateTime @default(now())

  deal        Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  lender      Lender   @relation(fields: [lenderId], references: [id], onDelete: Cascade)
}

// ------------------------------------------------------
// DOCUMENTS
// ------------------------------------------------------

model Document {
  id          String   @id @default(cuid())
  name        String
  type        String   // ID, PAY_STUB, NOA, APPRAISAL, PURCHASE_AGREEMENT
  url         String
  sizeBytes   Int?
  clientId    String?
  dealId      String?
  uploadedAt  DateTime @default(now())

  client      Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  deal        Deal?    @relation(fields: [dealId], references: [id], onDelete: Cascade)
}

model DocumentRequest {
  id          String   @id @default(cuid())
  dealId      String
  title       String
  description String?
  status      String   @default("REQUESTED") // REQUESTED, UPLOADED, VERIFIED, REJECTED
  requestedAt DateTime @default(now())
  
  deal        Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
}

// ------------------------------------------------------
// SCENARIOS & CALCULATORS
// ------------------------------------------------------

model Scenario {
  id              String   @id @default(cuid())
  dealId          String
  name            String
  isRecommended   Boolean  @default(false)
  totalAmount     Float
  blendedRate     Float?
  totalPayment    Float?
  totalFees       Float?
  qualificationResult String? // JSON containing stress test pass/fail reasons
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  deal            Deal              @relation(fields: [dealId], references: [id], onDelete: Cascade)
  tranches        ScenarioTranche[]
}

model ScenarioTranche {
  id          String   @id @default(cuid())
  scenarioId  String
  position    Int      // 1 = 1st, 2 = 2nd
  amount      Float
  rate        Float
  termMonths  Int
  amortMonths Int
  payment     Float
  lenderFee   Float?
  brokerFee   Float?

  scenario    Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
}

model CalculatorRun {
  id          String   @id @default(cuid())
  dealId      String?
  inputsJson  String   // The saved state of the calculator (property value, down payment, incomes, liabilities)
  outputsJson String   // The results (ratios, payments, cash required)
  createdAt   DateTime @default(now())

  deal        Deal?    @relation(fields: [dealId], references: [id], onDelete: Cascade)
}

// ------------------------------------------------------
// ACTIVITY FEED
// ------------------------------------------------------

model ActivityFeed {
  id          String   @id @default(cuid())
  type        String   // DEAL_MOVED, DOC_UPLOADED, NOTE_ADDED, MATCH_FOUND
  title       String
  description String?
  entityId    String?  // ID of the related deal or client
  actorId     String?
  createdAt   DateTime @default(now())

  actor       UserProfile? @relation(fields: [actorId], references: [id], onDelete: SetNull)
}
