{
    "compilerOptions": {
        "target": "ESNext",
        "module": "NodeNext",
        "lib": [
            "ESNext"
        ],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "baseUrl": ".",
        "moduleResolution": "NodeNext",
        "paths": {
            "@brokerbox/database": [
                "./packages/database/src/index.ts"
            ],
            "@brokerbox/ui": [
                "./packages/ui/src/index.ts"
            ],
            "@brokerbox/utils": [
                "./packages/utils/src/index.ts"
            ]
        },
        "types": [
            "node"
        ]
    },
    "exclude": [
        "node_modules"
    ]
}