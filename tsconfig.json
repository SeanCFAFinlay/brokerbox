{
    "compilerOptions": {
        "target": "ESNext",
        "module": "NodeNext",
        "lib": [
            "ESNext"
        ],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "baseUrl": ".",
        "moduleResolution": "NodeNext",
        "types": [
            "node"
        ]
    },
    "exclude": [
        "node_modules"
    ]
}