generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      Role
  createdAt DateTime @default(now())
  deals     Deal[]
}

model Client {
  id        String     @id @default(cuid())
  name      String
  email     String?
  phone     String?
  createdAt DateTime   @default(now())
  deals     Deal[]
  documents Document[]
}

model Lender {
  id        String   @id @default(cuid())
  name      String
  criteria  String?
  createdAt DateTime @default(now())
  deals     Deal[]
}

model Deal {
  id         String      @id @default(cuid())
  clientId   String
  lenderId   String?
  brokerId   String
  status     DealStatus  @default(NEW)
  amount     Float       @default(0)
  createdAt  DateTime    @default(now())

  client     Client      @relation(fields: [clientId], references: [id])
  lender     Lender?     @relation(fields: [lenderId], references: [id])
  broker     User        @relation(fields: [brokerId], references: [id])

  tasks      Task[]
  notes      Note[]
}

model Task {
  id        String   @id @default(cuid())
  dealId    String
  title     String
  done      Boolean  @default(false)
  createdAt DateTime @default(now())

  deal      Deal     @relation(fields: [dealId], references: [id])
}

model Note {
  id        String   @id @default(cuid())
  dealId    String
  body      String
  createdAt DateTime @default(now())

  deal      Deal     @relation(fields: [dealId], references: [id])
}

model Document {
  id        String   @id @default(cuid())
  clientId  String
  fileUrl   String
  type      String
  createdAt DateTime @default(now())

  client    Client   @relation(fields: [clientId], references: [id])
}

enum Role {
  BROKER
  CLIENT
  LENDER
}

enum DealStatus {
  NEW
  SUBMITTED
  APPROVED
  FUNDED
  DECLINED
}