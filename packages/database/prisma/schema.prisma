generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/client"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth & User ────────────────────────────────────────────────────────────────

model User {
  id                  String   @id @default(cuid())
  email               String   @unique
  passwordHash        String
  name                String   @default("Demo Broker")
  role                String   @default("broker") // admin | broker | readonly | lender_agent | borrower | investor
  baseCommissionSplit Float    @default(50) // %
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  lenderId            String?

  tasks         Task[]
  lender        Lender?        @relation(fields: [lenderId], references: [id])
  investments   Investment[]
  notifications Notification[]

  outlookAccessToken  String?
  outlookRefreshToken String?
  outlookTokenExpiry  DateTime?
  outlookEnabled      Boolean   @default(false)
}

// ─── Borrower ───────────────────────────────────────────────────────────────────

model Borrower {
  id               String    @id @default(cuid())
  firstName        String
  lastName         String
  email            String    @unique
  phone            String?
  address          String?
  city             String?
  province         String    @default("ON")
  postalCode       String?
  income           Float     @default(0)
  verifiedIncome   Float?
  employmentStatus String    @default("employed")
  borrowerType     String    @default("primary") // primary | co-borrower | guarantor
  liabilities      Float     @default(0)
  creditScore      Int       @default(650)
  creditScoreDate  DateTime?
  dateOfBirth      DateTime?
  coBorrowerName   String?
  coBorrowerEmail  String?
  notes            String?
  status           String    @default("active")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  deals       Deal[]
  scenarios   Scenario[]
  docRequests DocRequest[]
}

// ─── Lender ─────────────────────────────────────────────────────────────────────

model Lender {
  id           String  @id @default(cuid())
  name         String
  contactEmail String?
  contactPhone String?
  contactName  String?

  // Eligibility gates
  minCreditScore     Int      @default(600)
  maxLTV             Float    @default(80)
  maxGDS             Float    @default(39)
  maxTDS             Float    @default(44)
  supportedProvinces String[] @default(["ON"])
  propertyTypes      String[] @default(["residential"])

  // Product details
  positionTypes     String[] @default(["1st"]) // 1st, 2nd, 3rd, bridge
  productCategories String[] @default(["residential"]) // residential, commercial, land, construction, bridge
  minLoan           Float    @default(50000)
  maxLoan           Float    @default(5000000)
  termMin           Int      @default(6) // months
  termMax           Int      @default(360) // months

  // Pricing
  pricingPremium Float @default(0)
  baseRate       Float @default(5.5)
  lenderFees     Float @default(0) // % fee

  // Scoring attributes
  speed               Int @default(5)
  exceptionsTolerance Int @default(3)
  appetite            Int @default(5)

  // Capital tracking
  capitalAvailable Float @default(0)
  capitalCommitted Float @default(0)

  // Notes & docs
  notes                String?
  underwritingNotes    String?
  documentRequirements String[] @default([])

  status         String                @default("active")
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  deals          Deal[]
  users          User[]
  capitalPools   CapitalPool[]
  lenderMatchSnapshots LenderMatchSnapshot[]
}

// ─── Capital & Investors ────────────────────────────────────────────────────────

model CapitalPool {
  id              String @id @default(cuid())
  name            String
  totalAmount     Float
  availableAmount Float
  effectiveLTV    Float  @default(75) // Targeted max LTV for this pool
  utilizationRate Float  @default(0) // (Total - Available) / Total
  minInvestment   Float  @default(50000)
  targetYield     Float  @default(8.0)
  status          String @default("active") // active | closed

  lenderId String
  lender   Lender @relation(fields: [lenderId], references: [id])

  investments Investment[]
  loans       Loan[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Investment {
  id     String @id @default(cuid())
  amount Float
  yield  Float
  status String @default("active") // active | withdrawn

  poolId String
  pool   CapitalPool @relation(fields: [poolId], references: [id])
  userId String
  user   User        @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Deal ───────────────────────────────────────────────────────────────────────

model Deal {
  id         String  @id @default(cuid())
  borrowerId String
  lenderId   String?
  stage      String  @default("intake") // intake | in_review | matched | committed | funded | declined | archived
  priority   String  @default("normal") // low | normal | high | urgent

  // Property
  propertyAddress String?
  propertyType    String  @default("residential")
  propertyValue   Float   @default(0)

  // Loan
  loanAmount    Float   @default(0)
  interestRate  Float?
  termMonths    Int     @default(300)
  amortMonths   Int     @default(300)
  position      String  @default("1st") // 1st | 2nd | 3rd | bridge
  loanPurpose   String  @default("purchase") // purchase | refinance | renewal | equity_takeout | bridge | construction
  occupancyType String  @default("owner_occupied") // owner_occupied | rental | investment | commercial
  exitStrategy  String?

  // Ratios
  ltv            Float?
  gds            Float?
  tds            Float?
  monthlyPayment Float?
  matchScore     Int?

  // Fees & Commission
  brokerFee            Float?
  lenderFee            Float?
  totalRevenue         Float?
  agentCommissionSplit Float  @default(50) // %
  netBrokerageRevenue  Float?

  // Dates
  closingDate DateTime?
  fundingDate DateTime?
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  borrower       Borrower              @relation(fields: [borrowerId], references: [id], onDelete: Cascade)
  lender         Lender?               @relation(fields: [lenderId], references: [id])
  tasks          Task[]
  docRequests    DocRequest[]
  stageHistory   DealStageHistory[]
  scenarios      Scenario[]
  conditions     DealCondition[]
  loan           Loan?
  lenderMatchSnapshots LenderMatchSnapshot[]
  matchRuns            MatchRun[]
}

// ─── Deal Stage History ─────────────────────────────────────────────────────────

model DealStageHistory {
  id        String   @id @default(cuid())
  dealId    String
  fromStage String
  toStage   String
  changedBy String   @default("system")
  changedAt DateTime @default(now())

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)
}

// ─── Scenario ───────────────────────────────────────────────────────────────────

model Scenario {
  id                  String   @id @default(cuid())
  borrowerId          String
  dealId              String
  name                String
  type                String   @default("purchase") // purchase | refinance | renewal | bridge | construction | second
  status              String   @default("WORKING") // WORKING | RECOMMENDED | SUBMITTED
  inputs              Json     @default("{}")
  results             Json     @default("{}")
  exitCost            Float?
  isPreferred         Boolean  @default(false)
  recommendationNotes String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  borrower Borrower @relation(fields: [borrowerId], references: [id], onDelete: Cascade)
  deal     Deal     @relation(fields: [dealId], references: [id])
}

// ─── Match Snapshots ─────────────────────────────────────────────────────────────

model MatchRun {
  id        String   @id @default(cuid())
  dealId    String
  timestamp DateTime @default(now())

  deal      Deal                  @relation(fields: [dealId], references: [id], onDelete: Cascade)
  snapshots LenderMatchSnapshot[]

  @@index([dealId])
  @@index([timestamp])
}

model LenderMatchSnapshot {
  id         String   @id @default(cuid())
  dealId     String
  matchRunId String?
  lenderId   String
  score      Int
  passed     Boolean
  failures   String[]
  snapshot   Json // Full lender config at time of match
  timestamp  DateTime @default(now())

  deal     Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  lender   Lender    @relation(fields: [lenderId], references: [id])
  matchRun MatchRun? @relation(fields: [matchRunId], references: [id], onDelete: SetNull)

  @@index([dealId])
  @@index([matchRunId])
  @@index([lenderId])
}

// ─── Calendar & Events ──────────────────────────────────────────────────────────

model CalendarEvent {
  id          String   @id @default(cuid())
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  eventType   String // task | condition | closing | renewal
  sourceId    String // ID of the related task/deal/etc
  sourceType  String // Task | Deal | DealCondition
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sourceId, sourceType])
  @@index([startTime])
}

// ─── Loan Tracking & Management ──────────────────────────────────────────────────

model Loan {
  id     String @id @default(cuid())
  dealId String @unique
  deal   Deal   @relation(fields: [dealId], references: [id])

  poolId String?
  pool   CapitalPool? @relation(fields: [poolId], references: [id])

  status           String   @default("active") // active | paid_off | default | arrears
  fundedDate       DateTime
  maturityDate     DateTime
  principalBalance Float
  interestRate     Float
  interestType     String   @default("fixed") // fixed | variable

  payments LoanPayment[]
  fees     LoanFee[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dealId])
  @@index([poolId])
  @@index([status])
}

model LoanPayment {
  id     String @id @default(cuid())
  loanId String
  loan   Loan   @relation(fields: [loanId], references: [id])

  amount Float
  date   DateTime
  type   String   @default("regular") // regular | extra_principal | payoff
  status String   @default("cleared") // pending | cleared | bounced

  principalPortion Float?
  interestPortion  Float?

  createdAt DateTime @default(now())

  @@index([loanId])
  @@index([date])
}

model LoanFee {
  id     String @id @default(cuid())
  loanId String
  loan   Loan   @relation(fields: [loanId], references: [id])

  amount      Float
  description String
  type        String // late_fee | nsf_fee | discharge_fee | extension_fee
  isPaid      Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([loanId])
}

// ─── Notes (polymorphic) ────────────────────────────────────────────────────────

model Note {
  id         String   @id @default(cuid())
  entityType String // Borrower | Deal | Lender
  entityId   String
  content    String
  createdBy  String   @default("system")
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

// ─── Document & Condition System ────────────────────────────────────────────────

model DocRequest {
  id         String    @id @default(cuid())
  borrowerId String
  dealId     String?
  docType    String
  category   String    @default("general")
  status     String    @default("requested") // requested | uploaded | verified | rejected | expired
  expiresAt  DateTime?
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  borrower       Borrower        @relation(fields: [borrowerId], references: [id], onDelete: Cascade)
  deal           Deal?           @relation(fields: [dealId], references: [id])
  files          DocumentFile[]
  dealConditions DealCondition[]

  @@index([dealId])
  @@index([borrowerId])
  @@index([createdAt])
}

model DocumentFile {
  id           String   @id @default(cuid())
  docRequestId String
  filename     String
  path         String
  mimeType     String   @default("application/octet-stream")
  fileSize     Int      @default(0)
  version      Int      @default(1)
  uploadedAt   DateTime @default(now())

  docRequest DocRequest @relation(fields: [docRequestId], references: [id], onDelete: Cascade)

  @@index([docRequestId])
}

// ─── Deal Conditions ────────────────────────────────────────────────────────────

model DealCondition {
  id           String    @id @default(cuid())
  dealId       String
  description  String
  status       String    @default("pending") // pending | met | waived
  clearedAt    DateTime?
  docRequestId String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  deal       Deal        @relation(fields: [dealId], references: [id], onDelete: Cascade)
  docRequest DocRequest? @relation(fields: [docRequestId], references: [id], onDelete: SetNull)

  @@index([dealId])
  @@index([docRequestId])
}

// ─── Task ───────────────────────────────────────────────────────────────────────

model Task {
  id           String    @id @default(cuid())
  title        String
  description  String?
  dueDate      DateTime?
  status       String    @default("pending") // pending | completed
  priority     String    @default("normal") // low | normal | high | urgent
  assignedToId String?
  entityType   String? // Deal | Borrower | Lender
  entityId     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  assignedTo User?   @relation(fields: [assignedToId], references: [id])
  Deal       Deal?   @relation(fields: [dealId], references: [id])
  dealId     String?

  @@index([dealId])
  @@index([entityType, entityId])
  @@index([assignedToId])
}

// ─── Audit Log (Deal Activity) ──────────────────────────────────────────────────

model DealActivity {
  id        String   @id @default(cuid())
  actor     String   @default("demo") // userId or "system"
  actorName String   @default("System")
  entity    String // Deal | Borrower | Lender | CapitalPool
  entityId  String
  action    String // CREATE | UPDATE | DELETE | STATUS_CHANGE | MATCH_RUN
  diff      Json? // { field: { old, new } }
  metadata  Json? // Extra context
  timestamp DateTime @default(now())

  @@index([entity, entityId])
  @@index([timestamp])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("info") // info | success | warning | error | task | deal
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId, read])
  @@index([createdAt])
}

// ─── Brokerage Settings (singleton) ─────────────────────────────────────────────

model BrokerageSettings {
  id                  String @id @default("default")
  brokerageName       String @default("BrokerBox Financial Group")
  licenseNumber       String @default("")
  principalBroker     String @default("")
  officeAddress       String @default("")
  officePhone         String @default("")
  officeEmail         String @default("")
  defaultBrokerFee    Float  @default(1.0) // %
  defaultLenderFee    Float  @default(0.5) // %
  defaultTermMonths   Int    @default(12)
  defaultAmortMonths  Int    @default(300)
  defaultInterestRate Float  @default(5.5)
}
