# Database (Postgres: Neon/Supabase/Railway) – required for web app runtime
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"

# Auth
JWT_SECRET="change-me-long-random"

# API
API_PORT=3001

# Optional: Outlook/Microsoft Graph (apps/web)
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_TENANT_ID=
# AZURE_REDIRECT_URI=http://localhost:3000/api/auth/outlook/callback