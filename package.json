{
    "name": "brokerbox",
    "private": true,
    "packageManager": "pnpm@10.6.5",
    "scripts": {
        "dev": "turbo run dev",
        "build": "turbo run build",
        "lint": "turbo run lint",
        "typecheck": "turbo run typecheck",
        "db:generate": "pnpm -C apps/web db:generate",
        "db:migrate": "pnpm -C apps/web db:migrate",
        "db:push": "pnpm -C apps/web db:push",
        "db:seed": "pnpm -C apps/web db:seed",
        "api:dev": "pnpm -C packages/api dev",
        "api:build": "pnpm -C packages/api build"
    },
    "devDependencies": {
        "@expo/cli": "^55.0.14",
        "@types/minimatch": "^6.0.0",
        "@types/react-native": "^0.73.0"
    }
}